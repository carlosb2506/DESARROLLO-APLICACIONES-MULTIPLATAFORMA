<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.SampleController">
   <bottom>
      <Pane prefHeight="375.0" prefWidth="275.0" BorderPane.alignment="CENTER">
         <children>
            <TextField id="operando1" fx:id="txtNum1" layoutX="104.0" layoutY="65.0" />
            <TextField id="operando2" fx:id="txtNum2" layoutX="104.0" layoutY="113.0" />
            <TextField id="resultado" fx:id="txtResultado" layoutX="104.0" layoutY="285.0" />
            <Button id="btnSumar" layoutX="104.0" layoutY="149.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="149.0" text="Operar">
               <font>
                  <Font name="MV Boli" size="12.0" />
               </font>
            </Button>
            <Label layoutX="27.0" layoutY="69.0" text="Operando 1" />
            <Label layoutX="27.0" layoutY="117.0" text="Operando 2" />
            <Label layoutX="27.0" layoutY="289.0" text="Resultado" />
            <RadioButton fx:id="rbSuma" layoutX="90.0" layoutY="202.0" mnemonicParsing="false" text="Suma">
               <toggleGroup>
                  <ToggleGroup fx:id="Grupo" />
               </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="rbDivide" layoutX="90.0" layoutY="249.0" mnemonicParsing="false" text="División" toggleGroup="$Grupo" />
            <RadioButton fx:id="rbMultiplica" layoutX="167.0" layoutY="202.0" mnemonicParsing="false" text="Multiplicación" toggleGroup="$Grupo" />
            <RadioButton fx:id="rbResta" layoutX="167.0" layoutY="249.0" mnemonicParsing="false" text="Resta" toggleGroup="$Grupo" />
         </children>
      </Pane>
   </bottom>
</BorderPane>
